    "/api/audit-log": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "List all audit logs (admin-only)",
        "description": "Admin-only endpoint that returns a paginated view of all audit log records. Requires a valid x-admin-api-key header.",
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "description": "Maximum number of log records to return (1-200, default 50)",
              "example": 50
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "description": "Zero-based offset into the audit log list",
              "example": 0
            },
            "required": false,
            "name": "offset",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Filter logs by actor (Stellar address)",
              "example": "GAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAWHF"
            },
            "required": false,
            "name": "actor",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Filter logs by transition type",
              "example": "release"
            },
            "required": false,
            "name": "transition",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Filter logs by bounty ID",
              "example": "BNT-0001"
            },
            "required": false,
            "name": "bountyId",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Filter logs by fromStatus",
              "example": "submitted"
            },
            "required": false,
            "name": "fromStatus",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Filter logs by toStatus",
              "example": "released"
            },
            "required": false,
            "name": "toStatus",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of audit logs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BountyAuditLogListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing x-admin-api-key header",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
