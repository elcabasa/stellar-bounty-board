{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "env": {
    "node": true,
    "es2022": true
  },
  "ignorePatterns": ["dist", "node_modules", "*.config.js", "*.config.ts", "*.d.ts"],
  "overrides": [
    {
      "files": ["src/**/*.ts"],
      "rules": {
        "no-console": "error"
      }
    },
    {
      "files": ["test/**/*.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
